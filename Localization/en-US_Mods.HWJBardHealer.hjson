		DisplayName: Seraph Statuette
		Tooltip:
			'''
			Empower certain radiant attacks with dark energy
			Maximum life increased by 40
			Maximum mana increased by 20
			20% increased radiant damage
			15% increased healing speed
			12% increased radiant critical strike chance
			10% increased radiant casting speed
			Healing spells will heal 3 additional life 
			Taking fatal damage unleashes your inner spirit and you respawn twice as quickly 
			Your inner spirit will constantly release beams of healing energy towards your cursor
			'''
	}

	HarmonyHeadgear: {
		DisplayName: Harmony Headgear
		Tooltip:
			'''
			Increases maximum inspiration by 5
			Each unique empowerment you have increases your:
			Symphonic damage by 4%
			Symphonic playing speed by 2%
			Inspiration regeneration rate by 2%
			Movement speed by 2%
			'''
	}

	ThrowingGuideVolume4: {
		DisplayName: Guide to Expert Throwing : Volume IV
		Tooltip:
			'''
			15% increased thrower damage
			15% increased thrower velocity
			30% of your thrower damage is duplicated
			Enemies killed by your thrower damage release a spread of damaging coins
			Enemies damaged by the coins are gouged and drop more money on death
			'''
	}

	TriNote: {
		DisplayName: TriNote
